class Solution {
    public int minCostClimbingStairs(int[] cost) {
        int l=cost.length, ans=0;
        int dp[] = new int[l];
        dp[0]=cost[0];
        dp[1]=cost[1];
        for(int i=2;i<l;i++)
        {
            dp[i] = cost[i]+Math.min(dp[i-1],dp[i-2]);
        }
        return Math.min(dp[l-2],dp[l-1]);
    }
}
