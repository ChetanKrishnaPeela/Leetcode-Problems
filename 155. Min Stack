class MinStack {
    List<int[]> stack;
    int min_val;
    public MinStack() {
        stack = new ArrayList<>();
    }
    
    public void push(int val) {
        if(stack.isEmpty()) 
        {
            min_val = val;
        }
        else if(val < min_val) 
        {
            min_val = val;
        }
        stack.add(new int[]{val, min_val});
    }
    
    public void pop() {
        stack.remove(stack.size()-1);
        if(!stack.isEmpty()) {
            min_val = stack.get(stack.size() - 1)[1];
        }
    }
    
    public int top() {
        return stack.isEmpty() ? -1: stack.get(stack.size()-1)[0];
    }
    
    public int getMin() {
        return stack.isEmpty() ? -1: stack.get(stack.size()-1)[1];
    }
}

